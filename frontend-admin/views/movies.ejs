<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-gray-900 text-white min-h-screen">
  <%- include('partials/header') %>

  <main class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-3xl font-bold">Gestion des Films</h2>
      <button class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded font-semibold transition-colors">
        + Ajouter un Film
      </button>
    </div>
    <div class="bg-gray-800 rounded-lg overflow-hidden">
      <table class="w-full text-left">
        <thead class="bg-gray-700">
          <tr>
            <th class="px-6 py-3">Titre</th>
            <th class="px-6 py-3">Catégorie</th>
            <th class="px-6 py-3">Année</th>
            <th class="px-6 py-3">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (movies.length === 0) { %>
            <tr>
              <td colspan="4" class="px-6 py-8 text-center text-gray-400">
                Aucun film pour le moment.
              </td>
            </tr>
          <% } else { %>
            <% movies.forEach(movie => { %>
              <tr class="border-t border-gray-700">
                <td class="px-6 py-4"><%= movie.title %></td>
                <td class="px-6 py-4"><%= movie.category %></td>
                <td class="px-6 py-4"><%= movie.year %></td>
                <td class="px-6 py-4">
                  <button class="text-blue-400 hover:text-blue-300 mr-3">Modifier</button>
                  <button class="text-red-400 hover:text-red-300">Supprimer</button>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
